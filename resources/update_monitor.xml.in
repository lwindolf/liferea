<!DOCTYPE html>
<html>
<head>
        <script src='/js/vendor/handlebars.min.js'></script>
        
	<meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
        <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'unsafe-inline' 'unsafe-eval' *; style-src 'unsafe-inline'; img-src *; media-src *; object-src 'none'"/>

        <style>
                .update_monitor_feed {
                        float: left;
                        width: 0.8rem;
                        height: 0.8rem;
                        border: 1px solid gray;
                        margin-right: 0.1rem;
                        margin-bottom: 0.1rem;
                        display: block;
                }

                h2, h3 {
                        clear: both;
                        margin-bottom: 0.6rem;
                        margin-top: 0.6rem;
                }

                .update_monitor_status {
                        border: 1px solid gray;
                        padding-left: 0.1rem;
                        padding-right: 0.1rem;
                        display: inline-block;
                }

                .ok {
                        background: #ccf;
                        border-color: #66f
                        color: black;
                }
                .warn {
                        background: yellow;
                        border-color: #cc5;
                        color: black;
                }
                .bad {
                        background: red;
                        border-color: #a00;
                        color: white;
                }
                .updating {
                        background: purple;
                        border-color: #a0a;
                        color: white;
                }

                div {
                        margin-bottom: 0.2rem;
                        margin-top: 0.2rem;
                }
        </style>

        <script id="template" type="text/x-handlebars-template">
                {{#*inline "status"}}
                        {{#if updating}}updating{{else}}
                        {{#if error}}bad{{else}}
                        {{#compare age 'lt' interval}}ok{{else}}warn{{/compare}}
                        {{/if}}{{/if}}
                {{/inline}}

                {{#*inline "syncStatus"}}
                        {{#compare syncState '==' 0}}ok{{/compare}}
                        {{#compare syncState '>' 3}}updating{{else}}
                        {{#compare syncState '>' 0}}warn{{/compare}}
                        {{/compare}}
                {{/inline}}

                <div class="item" dir="{{direction}}">
                        <header class="content">
                                <h1>
                                        Update Monitor
                                </h1>

                                <div id="legend">
                                        Legend:
                                        <span class="update_monitor_status ok">OK</span>
                                        <span class="update_monitor_status updating">Updating</span>
                                        <span class="update_monitor_status warn">Outdated</span>
                                        <span class="update_monitor_status bad">Error</span>
                                </div>

                                <h2>Refresh State</h2>

                                <div id="update_monitor_feeds">
                                        {{#each feedlist.subscriptions}}
                                                <span class="update_monitor_feed update_monitor_status {{> status}}" title="{{title}} age={{age}} interval={{interval}}"></span>
                                        {{/each}}
                                </div>

                                <h2>Account Sync State</h2>

                                <div id="update_monitor_accounts">
                                        {{#each feedlist.nodeSources}}
                                                <h3>
                                                        {{title}}
                                                </h3>

                                                <div>
                                                        {{#compare state '==' 0}}<span class="update_monitor_status warn">Not connected yet.</span>{{/compare}}
                                                        {{#compare state '==' 1}}<span class="update_monitor_status warn">Logging in...</span>{{/compare}}
                                                        {{#compare state '==' 2}}<span class="update_monitor_status ok">Active</span>{{/compare}}
                                                        {{#compare state '==' 3}}<span class="update_monitor_status bad">Login failed!</span>{{/compare}}
                                                        {{#compare state '>' 3}}<span class="update_monitor_status warn">code {{state}}</span>{{/compare}}
                                                </div>

                                                <div class="update_monitor_sync_feeds">
                                                        {{#each ../feedlist.subscriptions}}
                                                                {{#compare nodeSourceId '===' ../id}}
                                                                {{#compare nodeSourceId '!==' id}}
                                                                        <span class="update_monitor_feed update_monitor_status {{> syncStatus}}" title="{{title}} syncState={{syncState}}"></span>
                                                                {{/compare}}
                                                                {{/compare}}
                                                        {{/each}}
                                                </div>
                                        {{else}}
                                                You currently have no online accounts configured.
                                        {{/each}}
                                </div>
                        </header>			

                        <div id="content" class="content">
                        </div>
                </div>
        </script>
</head>
<body>
        <noscript>ERROR: Javascript needs to be activated. Please report an issue with Liferea!</noscript>
</body>
<script type="module">
        import { load_update_monitor } from '/js/htmlview.js';

        window.load_update_monitor = load_update_monitor;
        window.onload = (e) => {
                REPLACE_MARKER
        };
</script>
</html>
