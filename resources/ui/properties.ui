<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0.2 -->
<interface>
  <!-- interface-name properties.ui -->
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.5"/>
  <object class="GtkAdjustment" id="adjustment4">
    <property name="step-increment">1</property>
    <property name="upper">10000</property>
  </object>
  <object class="GtkAdjustment" id="adjustment5">
    <property name="lower">1</property>
    <property name="step-increment">1</property>
    <property name="upper">10000</property>
    <property name="value">1</property>
  </object>
  <object class="GtkListStore" id="liststore6">
    <columns>
      <column type="gchararray"/>
    </columns>
  </object>
  <object class="AdwDialog" id="properties">
    <property name="title">Properties</property>
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="AdwHeaderBar"/>
        </child>
        <child>
          <object class="GtkNotebook" id="subscriptionPropNotebook">
            <property name="focusable">1</property>
            <child>
              <object class="GtkNotebookPage" id="generalTab">
                <property name="child">
                  <object class="GtkBox">
                    <property name="margin-bottom">12</property>
                    <property name="margin-end">12</property>
                    <property name="margin-start">12</property>
                    <property name="margin-top">12</property>
                    <property name="orientation">vertical</property>
                    <property name="spacing">12</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">Feed _Name</property>
                        <property name="mnemonic-widget">feedNameEntry</property>
                        <property name="use-underline">1</property>
                        <property name="xalign">0.0</property>
                        <accessibility>
                          <property name="orientation">horizontal</property>
                        </accessibility>
                        <attributes>
                          <attribute name="weight" value="bold"/>
                        </attributes>
                      </object>
                    </child>
                    <child>
                      <object class="GtkEntry" id="feedNameEntry">
                        <property name="activates-default">1</property>
                        <property name="focusable">1</property>
                        <property name="hexpand">1</property>
                        <property name="margin-start">12</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">Update _Interval</property>
                        <property name="mnemonic-widget">updateIntervalDefault</property>
                        <property name="use-underline">1</property>
                        <property name="xalign">0.0</property>
                        <attributes>
                          <attribute name="weight" value="bold"/>
                        </attributes>
                      </object>
                    </child>
                    <child>
                      <object class="GtkCheckButton" id="updateIntervalDefault">
                        <property name="active">1</property>
                        <property name="label" translatable="yes">_Use global default update interval.</property>
                        <property name="margin-start">12</property>
                        <property name="use-underline">1</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="spacing">12</property>
                        <child>
                          <object class="GtkCheckButton" id="updateIntervalSpecific">
                            <property name="group">updateIntervalDefault</property>
                            <property name="label" translatable="yes">_Feed specific update interval of</property>
                            <property name="margin-start">12</property>
                            <property name="use-underline">1</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkSpinButton" id="refreshIntervalSpinButton">
                            <property name="adjustment">adjustment5</property>
                            <property name="climb-rate">1</property>
                            <property name="focusable">1</property>
                            <property name="text" translatable="yes">1</property>
                            <property name="value">1</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkComboBox" id="refreshIntervalUnitComboBox">
                            <property name="model">liststore6</property>
                            <child>
                              <object class="GtkCellRendererText" id="cellrenderertext1"/>
                              <!-- Custom child fragments -->
                              <attributes>
                                <attribute name="text">0</attribute>
                              </attributes>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkCheckButton" id="updateIntervalNever">
                        <property name="group">updateIntervalDefault</property>
                        <property name="label" translatable="yes">_Don't update this feed automatically.</property>
                        <property name="margin-start">12</property>
                        <property name="use-underline">1</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="feedUpdateInfo">
                        <property name="halign">start</property>
                        <property name="label" translatable="yes">This feed provider suggests an update interval of %d minutes.</property>
                        <property name="wrap">1</property>
                      </object>
                    </child>
                  </object>
                </property>
                <property name="tab">
                  <object class="GtkLabel" id="tab1Label">
                    <property name="label" translatable="yes">General</property>
                  </object>
                </property>
              </object>
            </child>
            <child>
              <object class="GtkNotebookPage" id="sourceTab">
                <property name="child">
                  <object class="GtkBox">
                    <property name="margin-bottom">12</property>
                    <property name="margin-end">12</property>
                    <property name="margin-start">12</property>
                    <property name="margin-top">12</property>
                    <property name="orientation">vertical</property>
                    <property name="spacing">12</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">Type</property>
                        <property name="xalign">0.0</property>
                        <property name="yalign">0</property>
                        <attributes>
                          <attribute name="weight" value="bold"/>
                        </attributes>
                      </object>
                    </child>
                    <child>
                      <object class="GtkCheckButton" id="feed_loc_url">
                        <property name="active">1</property>
                        <property name="label" translatable="yes">_URL</property>
                        <property name="margin-start">24</property>
                        <property name="use-underline">1</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkCheckButton" id="feed_loc_command">
                        <property name="group">feed_loc_url</property>
                        <property name="label" translatable="yes">_Command</property>
                        <property name="margin-start">24</property>
                        <property name="use-underline">1</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="margin-start">24</property>
                        <property name="spacing">24</property>
                        <child>
                          <object class="GtkCheckButton" id="feed_loc_file">
                            <property name="group">feed_loc_url</property>
                            <property name="label" translatable="yes">_Local File</property>
                            <property name="use-underline">1</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="selectSourceFileButton">
                            <property name="focusable">1</property>
                            <property name="label" translatable="yes">Select File...</property>
                            <property name="use-underline">1</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">Source</property>
                        <property name="mnemonic-widget">sourceEntry</property>
                        <property name="use-underline">1</property>
                        <property name="xalign">0.0</property>
                        <attributes>
                          <attribute name="weight" value="bold"/>
                        </attributes>
                      </object>
                    </child>
                    <child>
                      <object class="GtkEntry" id="sourceEntry">
                        <property name="focusable">1</property>
                        <property name="margin-start">12</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkCheckButton" id="filterCheckbox">
                        <property name="focusable">1</property>
                        <property name="label" translatable="yes">Use conversion _filter</property>
                        <property name="margin-start">12</property>
                        <property name="use-underline">1</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">Liferea can use external filter scripts in order to access feeds and directories in non-supported formats.</property>
                        <property name="margin-start">12</property>
                        <property name="wrap">1</property>
                        <property name="xalign">0.0</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox" id="filterbox">
                        <property name="margin-start">12</property>
                        <property name="orientation">horizontal</property>
                        <property name="spacing">12</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">Convert _using:</property>
                            <property name="mnemonic-widget">filterEntry</property>
                            <property name="use-underline">1</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkEntry" id="filterEntry">
                            <property name="focusable">1</property>
                            <property name="hexpand">1</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="filterSelectFile">
                            <property name="focusable">1</property>
                            <property name="label" translatable="yes">Select File...</property>
                            <property name="use-underline">1</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
                <property name="position">1</property>
                <property name="tab">
                  <object class="GtkLabel">
                    <property name="label" translatable="yes">Source</property>
                  </object>
                </property>
              </object>
            </child>
            <child>
              <object class="GtkNotebookPage" id="archiveTab">
                <property name="child">
                  <object class="GtkBox">
                    <property name="margin-bottom">12</property>
                    <property name="margin-end">12</property>
                    <property name="margin-start">12</property>
                    <property name="margin-top">12</property>
                    <property name="orientation">vertical</property>
                    <property name="spacing">12</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="label" translatable="yes">Control how the contents of feeds are saved when Liferea exits.

&lt;b&gt;Note:&lt;/b&gt; Items marked "important" are kept forever.</property>
                        <property name="use-markup">True</property>
                        <property name="wrap">1</property>
                        <property name="xalign">0.0</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkCheckButton" id="feedCacheDefault">
                        <property name="active">1</property>
                        <property name="label" translatable="yes">_Default cache settings</property>
                        <property name="use-underline">1</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkCheckButton" id="feedCacheDisable">
                        <property name="group">feedCacheDefault</property>
                        <property name="label" translatable="yes">Di_sable cache</property>
                        <property name="use-underline">1</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkCheckButton" id="feedCacheUnlimited">
                        <property name="group">feedCacheDefault</property>
                        <property name="label" translatable="yes">_Unlimited cache</property>
                        <property name="use-underline">1</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="spacing">12</property>
                        <child>
                          <object class="GtkCheckButton" id="feedCacheLimited">
                            <property name="group">feedCacheDefault</property>
                            <property name="halign">start</property>
                            <property name="label" translatable="yes">_Number of items to save:</property>
                            <property name="use-underline">1</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkSpinButton" id="cacheItemLimit">
                            <property name="adjustment">adjustment4</property>
                            <property name="climb-rate">1</property>
                            <property name="focusable">1</property>
                            <property name="halign">start</property>
                            <property name="numeric">1</property>
                            <property name="snap-to-ticks">1</property>
                            <property name="text" translatable="yes">0</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
                <property name="position">2</property>
                <property name="tab">
                  <object class="GtkLabel">
                    <property name="label" translatable="yes">Archive</property>
                  </object>
                </property>
              </object>
            </child>
            <child>
              <object class="GtkNotebookPage" id="downloadTab">
                <property name="child">
                  <object class="GtkBox">
                    <property name="margin-bottom">12</property>
                    <property name="margin-end">12</property>
                    <property name="margin-start">12</property>
                    <property name="margin-top">12</property>
                    <property name="orientation">vertical</property>
                    <property name="spacing">12</property>
                    <child>
                      <object class="GtkCheckButton" id="HTTPauthCheck">
                        <property name="focusable">1</property>
                        <property name="label" translatable="yes">Use HTTP _authentication</property>
                        <property name="use-underline">1</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox" id="httpAuthBox">
                        <property name="margin-start">32</property>
                        <property name="orientation">vertical</property>
                        <property name="spacing">12</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">User_name:</property>
                            <property name="mnemonic-widget">usernameEntry</property>
                            <property name="use-underline">1</property>
                            <property name="xalign">0.0</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkEntry" id="usernameEntry">
                            <property name="focusable">1</property>
                            <property name="hexpand">1</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">_Password:</property>
                            <property name="mnemonic-widget">passwordEntry</property>
                            <property name="use-underline">1</property>
                            <property name="xalign">0.0</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkEntry" id="passwordEntry">
                            <property name="focusable">1</property>
                            <property name="hexpand">1</property>
                            <property name="visibility">0</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkCheckButton" id="dontUseProxyCheck">
                        <property name="focusable">1</property>
                        <property name="label" translatable="yes">_Don't use proxy for download</property>
                        <property name="use-underline">1</property>
                      </object>
                    </child>
                  </object>
                </property>
                <property name="position">3</property>
                <property name="tab">
                  <object class="GtkLabel">
                    <property name="label" translatable="yes">Download</property>
                  </object>
                </property>
              </object>
            </child>
            <child>
              <object class="GtkNotebookPage" id="advancedTab">
                <property name="child">
                  <object class="GtkBox">
                    <property name="accessible-role">form</property>
                    <property name="margin-bottom">12</property>
                    <property name="margin-end">12</property>
                    <property name="margin-start">12</property>
                    <property name="margin-top">12</property>
                    <property name="orientation">vertical</property>
                    <property name="spacing">12</property>
                    <child>
                      <object class="GtkCheckButton" id="enclosureDownloadCheck">
                        <property name="focusable">1</property>
                        <property name="label" translatable="yes">_Automatically download all enclosures of this feed.</property>
                        <property name="use-underline">1</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkCheckButton" id="loadItemLinkCheck">
                        <property name="focusable">1</property>
                        <property name="label" translatable="yes">Auto-_load item link in configured browser when selecting articles.</property>
                        <property name="use-underline">1</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkCheckButton" id="ignoreCommentFeeds">
                        <property name="focusable">1</property>
                        <property name="label" translatable="yes">Ignore _comment feeds for this subscription.</property>
                        <property name="use-underline">1</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkCheckButton" id="markAsReadCheck">
                        <property name="focusable">1</property>
                        <property name="label" translatable="yes">_Mark downloaded items as read.</property>
                        <property name="use-underline">1</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkCheckButton" id="html5ExtractCheck">
                        <property name="focusable">1</property>
                        <property name="label" translatable="yes">Extract full content from HTML5 and Google AMP</property>
                        <property name="use-underline">1</property>
                      </object>
                    </child>
                  </object>
                </property>
                <property name="position">4</property>
                <property name="tab">
                  <object class="GtkLabel" id="enctablabel">
                    <property name="label" translatable="yes">Advanced</property>
                    <accessibility>
                      <property name="orientation">vertical</property>
                      <property name="value-max">-0.1</property>
                    </accessibility>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="applyBtn">
            <property name="css-classes">suggested-action</property>
            <property name="halign">end</property>
            <property name="label">_Apply</property>
            <property name="margin-bottom">12</property>
            <property name="margin-end">12</property>
            <property name="margin-start">12</property>
            <property name="margin-top">12</property>
            <property name="use-underline">True</property>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
