<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0.2 -->
<interface>
  <!-- interface-name opml_source.ui -->
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.5"/>
  <object class="AdwDialog" id="opml_source">
    <property name="focus-widget">locationEntry</property>
    <property name="title">New OPML Source</property>
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="AdwHeaderBar"/>
        </child>
        <child>
          <object class="GtkBox">
            <property name="margin-bottom">12</property>
            <property name="margin-end">12</property>
            <property name="margin-start">12</property>
            <property name="margin-top">12</property>
            <property name="orientation">vertical</property>
            <property name="spacing">12</property>
            <child>
              <object class="GtkLabel" id="label1">
                <property name="label" translatable="yes">Please specify a local file or an URL pointing to a valid OPML feed list.</property>
                <property name="valign">center</property>
                <property name="wrap">1</property>
              </object>
            </child>
            <child>
              <object class="GtkBox" id="hbox1">
                <property name="can-focus">0</property>
                <property name="spacing">6</property>
                <child>
                  <object class="AdwEntryRow" id="locationEntry">
                    <property name="hexpand">True</property>
                    <property name="title">Location</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="select_button">
                    <property name="focusable">1</property>
                    <property name="halign">center</property>
                    <property name="label" translatable="yes">_Select File</property>
                    <property name="use-underline">1</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="applyBtn">
                <property name="css-classes">suggested-action</property>
                <property name="focusable">1</property>
                <property name="halign">end</property>
                <property name="label" translatable="yes">_Add</property>
                <property name="use-underline">True</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
