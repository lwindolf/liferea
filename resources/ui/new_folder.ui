<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0.2 -->
<interface>
  <!-- interface-name new_folder.ui -->
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.7"/>
  <object class="AdwDialog" id="new_folder">
    <property name="accessible-role">form</property>
    <property name="focus-widget">foldertitleentry</property>
    <property name="follows-content-size">True</property>
    <property name="width-request">400</property>
    <child>
      <object class="GtkBox">
        <property name="margin-bottom">12</property>
        <property name="margin-end">12</property>
        <property name="margin-start">12</property>
        <property name="margin-top">12</property>
        <property name="orientation">vertical</property>
        <property name="spacing">12</property>
        <child>
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="spacing">12</property>
            <child>
              <object class="GtkLabel" id="titleLabel">
                <property name="css-classes">title-</property>
                <property name="label">New Folder</property>
              </object>
            </child>
            <child>
              <object class="AdwEntryRow" id="foldertitleentry">
                <property name="title">Folder Name</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="halign">end</property>
            <property name="spacing">12</property>
            <child>
              <object class="GtkButton" id="cancelBtn">
                <property name="label">_Cancel</property>
                <property name="use-underline">True</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="applyBtn">
                <property name="css-classes">suggested-action</property>
                <property name="label">_Create</property>
                <property name="use-underline">True</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
