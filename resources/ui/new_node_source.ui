<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0.2 -->
<interface>
  <!-- interface-name google_source.ui -->
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.6"/>
  <object class="AdwDialog" id="new_node_source">
    <property name="focus-widget">usernameEntry</property>
    <property name="title">New Account</property>
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="AdwHeaderBar">
            <property name="width-request">400</property>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="margin-bottom">12</property>
            <property name="margin-end">12</property>
            <property name="margin-start">12</property>
            <property name="margin-top">12</property>
            <property name="orientation">vertical</property>
            <property name="spacing">12</property>
            <child>
              <object class="GtkLabel" id="label">
                <property name="halign">start</property>
                <property name="hexpand">True</property>
                <property name="label">LABEL REPLACEME</property>
                <property name="use-markup">True</property>
                <property name="wrap">True</property>
              </object>
            </child>
            <child>
              <object class="AdwEntryRow" id="nameEntry">
                <property name="title">Title in feed list</property>
              </object>
            </child>
            <child>
              <object class="AdwEntryRow" id="usernameEntry">
                <property name="title">Username</property>
              </object>
            </child>
            <child>
              <object class="AdwPasswordEntryRow" id="passwordEntry">
                <property name="title">Password</property>
              </object>
            </child>
            <child>
              <object class="AdwEntryRow" id="serverEntry">
                <property name="input-purpose">url</property>
                <property name="text">https://</property>
                <property name="title">Server</property>
                <property name="visible">False</property>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="halign">end</property>
                <property name="spacing">12</property>
                <child>
                  <object class="GtkButton" id="applyBtn">
                    <property name="css-classes">suggested-action</property>
                    <property name="label">_Add</property>
                    <property name="use-underline">True</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
