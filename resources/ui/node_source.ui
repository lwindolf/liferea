<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0 -->
<interface>
  <!-- interface-name node_source.ui -->
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.5"/>
  <object class="AdwDialog" id="node_source">
    <property name="child">
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <child>
          <object class="AdwHeaderBar">
            <property name="show-end-title-buttons">False</property>
            <property name="title-widget">
              <object class="GtkLabel">
                <property name="label">Select source</property>
              </object>
            </property>
            <child>
              <object class="GtkButton" id="cancelBtn">
                <property name="label">_Cancel</property>
                <property name="use-underline">True</property>
              </object>
            </child>
            <child type="end">
              <object class="GtkButton" id="applyBtn">
                <property name="css-classes">suggested-action</property>
                <property name="label">_Add</property>
                <property name="sensitive">False</property>
                <property name="use-underline">True</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkScrolledWindow" id="scrolledwindow1">
            <property name="child">
              <object class="GtkTreeView" id="type_list">
                <property name="focusable">1</property>
                <property name="headers-visible">0</property>
                <property name="margin-bottom">12</property>
                <property name="margin-end">12</property>
                <property name="margin-start">12</property>
                <property name="margin-top">12</property>
                <property name="width-request">400</property>
                <child internal-child="selection">
                  <object class="GtkTreeSelection" id="treeview-selection"/>
                </child>
              </object>
            </property>
            <property name="focusable">1</property>
            <property name="hscrollbar-policy">never</property>
            <property name="vexpand">1</property>
          </object>
        </child>
      </object>
    </property>
    <property name="default-widget">applyBtn</property>
    <property name="focus-widget">type_list</property>
    <property name="follows-content-size">True</property>
    <property name="height-request">300</property>
  </object>
</interface>
